# ============================================================
# PERMIT MINER — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- API Keys ---
APOLLO_API_KEY=your_apollo_api_key_here
LOB_LIVE_KEY=live_your_lob_live_key_here
LOB_TEST_KEY=test_your_lob_test_key_here

# --- WordPress shared secret (set same value in permit-miner.php) ---
PERMIT_MINER_API_KEY=generate_a_random_32char_secret_here

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=henry@getlivewire.com
SMTP_PASS=your_app_password_here

# --- Recipients ---
PREVIEW_RECIPIENTS=henry@getlivewire.com
DIGEST_RECIPIENTS=henry@getlivewire.com,sales@getlivewire.com
ALERT_RECIPIENTS=henry@getlivewire.com

# --- Return Address (printed on postcard back) ---
RETURN_NAME=Livewire
RETURN_ADDRESS=4900 W Clay St
RETURN_CITY=Richmond
RETURN_STATE=VA
RETURN_ZIP=23230

# --- PURL landing page base ---
PURL_BASE_URL=https://getlivewire.com/welcome

# --- Lob Template IDs (set after uploading templates to lob.com) ---
LOB_TEMPLATE_FRONT_ID=tmpl_xxxxxxxxxxxxxxx
LOB_TEMPLATE_BACK_ID=tmpl_xxxxxxxxxxxxxxx
# Optional: separate drip templates (leave blank to reuse main templates)
LOB_DRIP_TEMPLATE_FRONT_ID=
LOB_DRIP_TEMPLATE_BACK_ID=

# --- Per-segment Lob templates ---
# Each unset var falls back to LOB_TEMPLATE_*_ID above, so segments can be
# phased in one at a time. Set these after Loud Canvas (or whoever) uploads
# the four segment-specific templates to Lob.
LOB_NC_FRONT=        # new_construction
LOB_NC_BACK=
LOB_MR_FRONT=        # major_remodel
LOB_MR_BACK=
LOB_KB_FRONT=        # kitchen_bath
LOB_KB_BACK=
LOB_OL_FRONT=        # outdoor_living
LOB_OL_BACK=
# Drip (second-touch) segment overrides — each unset var falls back to the
# first-touch segment template, which falls back to the generic template.
LOB_DRIP_NC_FRONT=
LOB_DRIP_NC_BACK=
LOB_DRIP_MR_FRONT=
LOB_DRIP_MR_BACK=
LOB_DRIP_KB_FRONT=
LOB_DRIP_KB_BACK=
LOB_DRIP_OL_FRONT=
LOB_DRIP_OL_BACK=

# --- Mode: "test" uses Lob test key and logs instead of sending ---
MODE=test

# --- Database ---
DB_PATH=permit_miner.db
